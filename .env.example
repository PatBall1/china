# Copy to .env and fill in. .env is gitignored.

# --- Amadeus Self-Service API (primary cost optimizer) ----------------------
# Create a free app at https://developers.amadeus.com to get a key + secret.
# 'test' works immediately; 'production' (also free, one click to enable) has
# fuller inventory + higher quota.
AMADEUS_CLIENT_ID=your_amadeus_api_key_here
AMADEUS_CLIENT_SECRET=your_amadeus_api_secret_here
AMADEUS_ENV=test

# --- Skyscanner via RapidAPI (secondary fare lookup) ------------------------
# https://rapidapi.com -> search "Skyscanner". Subscribe to an endpoint, then
# copy your key + the exact host below.
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_SKYSCANNER_HOST=sky-scanner3.p.rapidapi.com

# --- Shared market / currency / locale --------------------------------------
SKYSCANNER_MARKET=UK
SKYSCANNER_CURRENCY=GBP
SKYSCANNER_LOCALE=en-GB
