# Copy to .env and fill in. .env is gitignored.

# Skyscanner via RapidAPI (https://rapidapi.com -> search "Skyscanner").
# Subscribe to a Skyscanner endpoint, then copy your key + the exact host below.
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_SKYSCANNER_HOST=sky-scanner3.p.rapidapi.com

# Market / currency / locale used for fare queries.
SKYSCANNER_MARKET=UK
SKYSCANNER_CURRENCY=GBP
SKYSCANNER_LOCALE=en-GB
